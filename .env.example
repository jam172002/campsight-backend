# CampSight Scraper — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# For local development: copy this file to .env
# On Render.com: paste each value into the Environment tab (never commit .env)

# ── Firebase ──────────────────────────────────────────────────────────────────

# Your Firebase project ID (visible in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=campsight-2ff0e

# Full contents of your Firebase service account JSON, on a single line.
#
# How to get it:
#   1. Firebase Console → Project Settings → Service Accounts
#   2. Click "Generate New Private Key" → download the JSON file
#   3. Convert to a single line:
#        Mac/Linux:  cat your-key.json | tr -d '\n'
#        Windows PS: (Get-Content your-key.json) -join ''
#   4. Paste the result as the value below
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"campsight-2ff0e",...}

# ── Security ──────────────────────────────────────────────────────────────────

# Secret key for the POST /trigger admin endpoint.
# Anyone with this key can manually trigger the scraper engine.
# Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRIGGER_SECRET=replace-with-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────────

# Port — Render.com sets this automatically. Do not change.
PORT=10000

# ── Render.com (auto-set, do not configure manually) ─────────────────────────
# Render sets RENDER_EXTERNAL_URL to your service's public URL automatically.
# The backend uses it to self-ping every 14 minutes and stay warm.
# RENDER_EXTERNAL_URL=https://campsight-scraper.onrender.com
